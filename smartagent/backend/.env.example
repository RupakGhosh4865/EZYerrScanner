# ── Smartsheet API ─────────────────────────────────────────────────────────
# Mode: mock (WireMock) or live (real Smartsheet API)
USE_MOCK_SERVER=true

# Used when USE_MOCK_SERVER=true (local dev)
SMARTSHEET_MOCK_URL=http://localhost:8082

# Used when USE_MOCK_SERVER=false (production)
# Get token: Smartsheet → Account → Personal Settings → API Access
SMARTSHEET_ACCESS_TOKEN=your_real_token_here

# ── LLM (optional — only needed if using AI-powered schema detection) ───────
# GROQ_API_KEY=your_groq_key_here
# OPENAI_API_KEY=your_openai_key_here
